# === Gemini API ===
# Obtén tu key gratis en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# === Telegram Bot ===
# 1) Search @BotFather on Telegram → /newbot → follow prompts → get TOKEN.
TELEGRAM_BOT_TOKEN=123456789:ABC...

# 2) Send any message to your new bot.
# 3) Talk to @userinfobot to get your numeric CHAT_ID instantly.
TELEGRAM_CHAT_ID=123456789

# === Groq API (optional but recommended — primary backend, 14,400 req/day free) ===
# Get a free key at: https://console.groq.com
# If set, Groq (LLaMA 3.3 70B) runs first; Gemini is the automatic fallback.
# If not set, Gemini is used exclusively.
GROQ_API_KEY=gsk_...

# === Optional settings ===
MIN_SCORE=70
MAX_JOBS_PER_RUN=15
LOG_LEVEL=INFO
# GEMINI_MODEL=gemini-2.0-flash
# GROQ_MODEL=llama-3.3-70b-versatile
