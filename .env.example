# === Gemini API ===
# Obtén tu key gratis en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# === Telegram Bot ===
# 1) Search @BotFather on Telegram → /newbot → follow prompts → get TOKEN.
TELEGRAM_BOT_TOKEN=123456789:ABC...

# 2) Send any message to your new bot.
# 3) Talk to @userinfobot to get your numeric CHAT_ID instantly.
TELEGRAM_CHAT_ID=123456789

# === Optional settings ===
MIN_SCORE=70
MAX_JOBS_PER_RUN=15
LOG_LEVEL=INFO
